PORT=4000
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI-compatible cloud API
# CLOUD_PROVIDER supports: openai | anthropic
CLOUD_PROVIDER=openai
CLOUD_BASE_URL=https://api.openai.com
CLOUD_API_KEY=replace-me
CLOUD_MODEL=gpt-4o

# Ablation arm. One of:
#   full         (default) — SLM rewrite + function-name extraction
#   names_only   — NO LLM; raw prompt with deterministic function-name prefix
#   regex_strip  — NO LLM; deterministic multilingual pleasantry stripper
#   llm_no_names — SLM rewrite with function-name extraction disabled
PROXY_MODE=names_only

# ----------------------------------------------------------------------------
# LLMLingua-2 baseline proxy (llmlingua2_proxy.py)
# Only used when you run the Python proxy. The TypeScript proxy ignores these.
# Run on a different PORT so both proxies can be benchmarked side-by-side.
# ----------------------------------------------------------------------------
# PORT=4001                                                    # default 4001 for llmlingua2_proxy.py
# LLMLINGUA_MODEL=microsoft/llmlingua-2-xlm-roberta-large-meetingbank
# LLMLINGUA_RATE=0.6                                           # fraction of tokens to KEEP (0.6 ~= 40% reduction)
# LLMLINGUA_TARGET_TOKEN=0                                     # absolute target; overrides RATE when >0
# LLMLINGUA_DEVICE=cpu                                         # or cuda / mps
# LLMLINGUA_PRESERVE_ASSERTS=true                              # split assert lines, compress only the NL spec
# TOKEN_BUDGET_THRESHOLD=0.95                                  # forward raw when compressed >= 95% of raw
